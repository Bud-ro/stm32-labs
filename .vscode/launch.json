{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug STM32 Lab",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "cwd": "${workspaceFolder}",
            "executable": "zig-out/bin/${input:labName}",
            "gdbPath": "gdb-multiarch",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32g0x.cfg"
            ],
            "preLaunchTask": "Build Lab ${input:labName}",
            "device": "STM32G071RB",
            "runToEntryPoint": "main",
            "svdFile": "nucleo-g071rb/STM32G071.svd"
        }
    ],
    "inputs": [
        {
            "id": "labName",
            "type": "pickString",
            "description": "Which lab to build and debug?",
            "options": [
                "lab-03",
                "lab-04",
                "lab-05",
                "lab-06",
                "lab-07",
                "lab-08"
            ],
            "default": "lab-03"
        }
    ]
}